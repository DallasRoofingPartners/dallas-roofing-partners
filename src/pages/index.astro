---
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Dallas Roofing & Insurance Restoration | Free Roof Inspection</title>

    <meta
      name="description"
      content="Dallas roofing specialists for storm damage, roof replacement, and insurance restoration. Free inspections and insurance claim assistance."
    />

    <meta
      name="keywords"
      content="Dallas roofing, roof repair Dallas, roof replacement Dallas, storm damage roofing, insurance restoration Dallas"
    />

    <meta name="robots" content="index, follow" />
  </head>

  <body>
    <header>
      <div class="container">
        <h1>Dallas Roofing & Insurance Restoration Specialists</h1>

        <p>
          Storm damage inspections, insurance claim assistance, roof repair, and
          full roof replacement throughout Dallas and surrounding areas.
        </p>

        <div class="hero-buttons">
          <a href="#contact" class="btn btn-primary">
            Get Free Roof Inspection
          </a>

          <a href="tel:+12145551234" class="btn btn-secondary"> Call Now </a>
        </div>

        <p style="margin-top:25px;font-size:0.95rem;">
          ✔ Free inspections &nbsp; ✔ Insurance claim support &nbsp; ✔ Local
          Dallas roofing experts
        </p>
      </div>
    </header>

    <div class="trust-bar">
      Licensed • Insured • Storm Damage Specialists • Insurance Restoration
    </div>

    <section>
      <div class="container">
        <h2>Roofing Services</h2>

        <p class="section-text">
          Professional roofing and storm restoration services designed to help
          homeowners recover quickly after hail, wind, and storm damage.
        </p>

        <div class="grid">
          <div class="card">
            <h3>Storm Damage Inspections</h3>
            <p>Detailed inspections with documentation for insurance claims.</p>
          </div>

          <div class="card">
            <h3>Insurance Claim Assistance</h3>
            <p>
              We help homeowners navigate the insurance restoration process.
            </p>
          </div>

          <div class="card">
            <h3>Roof Repair</h3>
            <p>
              Fast repairs for leaks, missing shingles, and damaged roofing
              systems.
            </p>
          </div>

          <div class="card">
            <h3>Roof Replacement</h3>
            <p>Full roof replacement using high-quality roofing materials.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="process">
      <div class="container">
        <h2>Our Process</h2>

        <p class="section-text">
          A simple process focused on fast inspections, accurate documentation,
          and quality roofing work.
        </p>

        <ol>
          <li>Schedule your free roof inspection</li>
          <li>We inspect and document storm damage</li>
          <li>Insurance claim assistance and adjuster coordination</li>
          <li>Roof repair or full replacement completion</li>
        </ol>
      </div>
    </section>

    <section>
      <div class="container">
        <h2>Common Roof Problems We Find</h2>

        <div class="grid">
          <div class="card">
            <h3>Hidden Hail Damage</h3>
            <p>Damage often invisible from the ground after severe storms.</p>
          </div>

          <div class="card">
            <h3>Wind Damage</h3>
            <p>Missing shingles and lifted roofing materials after storms.</p>
          </div>

          <div class="card">
            <h3>Roof Leaks</h3>
            <p>Interior water damage caused by compromised roofing systems.</p>
          </div>

          <div class="card">
            <h3>Insurance Underpayment</h3>
            <p>Claims that fail to account for full storm-related damage.</p>
          </div>
        </div>
      </div>
    </section>

    <section>
      <div class="container">
        <div class="cta">
          <h2>Is Your Roof Storm-Damaged?</h2>

          <p>
            Small roofing issues can become major repair costs if ignored.
            Schedule a free inspection today.
          </p>

          <a href="#contact" class="btn btn-primary">
            Request Free Inspection
          </a>
        </div>
      </div>
    </section>

    <section id="contact">
      <div class="container">
        <h2>Request Free Roof Inspection</h2>

        <p class="section-text">
          Submit your information and we’ll contact you to schedule an
          inspection.
        </p>

        <form>
          <input type="text" placeholder="Full Name" required />

          <input type="tel" placeholder="Phone Number" required />

          <input type="text" placeholder="Property Address" required />

          <select>
            <option>Storm Damage</option>
            <option>Roof Leak</option>
            <option>Roof Replacement</option>
            <option>Insurance Claim Help</option>
          </select>

          <textarea rows="5" placeholder="Describe your roofing issue"
          ></textarea>

          <button type="submit"> Get Free Inspection </button>
        </form>
      </div>
    </section>

    <footer>
      <p>© 2026 Dallas Roofing Partners. All rights reserved.</p>
    </footer>
  </body>
</html>
