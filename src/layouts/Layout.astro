---
import "../styles/global.css";

const {
  title = "Dallas Roofing Partners",
  description = "Dallas roofing and insurance restoration specialists.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />

    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>

    <meta name="description" content={description} />

    <meta name="robots" content="index, follow" />
  </head>

  <body>
    <slot />
  </body>
</html>
